datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

// ─── Identidade ────────────────────────────────────────────────
// User = pessoa. Plano/assinatura NÃO mora mais no User: mora no
// Workspace (tenant). Um User acessa N workspaces via Membership.

model User {
  id          String       @id @default(cuid())
  name        String?
  email       String       @unique
  password    String?
  image       String?
  role        String       @default("couple") // papel global do produto
  memberships Membership[]
  accounts    Account[]
  sessions    Session[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model ProcessedStripeEvent {
  id        String   @id
  type      String
  createdAt DateTime @default(now())
}

// ─── Tenant (Multi-tenant B2B) ─────────────────────────────────
// Workspace é a unidade de isolamento e de cobrança. Toda Wedding
// pertence a um Workspace; o acesso é concedido via Membership.

model Workspace {
  id                   String       @id @default(cuid())
  name                 String
  slug                 String       @unique
  plan                 String       @default("free") // free | pro | gestor (ver src/lib/plans.ts)
  stripeCustomerId     String?      @unique
  stripeSubscriptionId String?      @unique
  memberships          Membership[]
  weddings             Wedding[]
  createdAt            DateTime     @default(now())
  updatedAt            DateTime     @updatedAt
}

model Membership {
  id          String    @id @default(cuid())
  role        String    @default("owner") // owner | admin | member
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  createdAt   DateTime  @default(now())

  @@unique([userId, workspaceId])
  @@index([workspaceId])
  @@index([userId])
}

// ─── Domínio ───────────────────────────────────────────────────

model Wedding {
  id             String              @id @default(cuid())
  title          String
  date           DateTime
  budgetTotal    Int                 @default(0)
  workspaceId    String
  workspace      Workspace           @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  guests         Guest[]
  tables         Table[]
  expenses       Expense[]
  guestRelations GuestRelationship[]
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt

  @@index([workspaceId])
}

model Guest {
  id                  String              @id @default(cuid())
  name                String
  email               String?
  phone               String?
  rsvpStatus          String              @default("pending")
  rsvpToken           String              @unique @default(cuid())
  dietaryRestrictions String?
  notes               String?
  weddingId           String
  wedding             Wedding             @relation(fields: [weddingId], references: [id], onDelete: Cascade)
  seatId              String?             @unique
  seat                Seat?               @relation("GuestSeat", fields: [seatId], references: [id])
  relationshipsFrom   GuestRelationship[] @relation("FromGuest")
  relationshipsTo     GuestRelationship[] @relation("ToGuest")
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt

  @@index([weddingId])
}

model Table {
  id        String   @id @default(cuid())
  name      String
  shape     String   @default("round")
  capacity  Int
  weddingId String
  wedding   Wedding  @relation(fields: [weddingId], references: [id], onDelete: Cascade)
  seats     Seat[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([weddingId])
}

model Seat {
  id        String   @id @default(cuid())
  number    Int
  tableId   String
  table     Table    @relation(fields: [tableId], references: [id], onDelete: Cascade)
  guest     Guest?   @relation("GuestSeat")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([tableId, number])
  @@index([tableId])
}

model Expense {
  id          String    @id @default(cuid())
  category    String
  description String?
  amount      Int
  paid        Int       @default(0)
  dueDate     DateTime?
  weddingId   String
  wedding     Wedding   @relation(fields: [weddingId], references: [id], onDelete: Cascade)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([weddingId])
}

model GuestRelationship {
  id        String   @id @default(cuid())
  type      String
  guestId   String
  guest     Guest    @relation("FromGuest", fields: [guestId], references: [id], onDelete: Cascade)
  relatedId String
  related   Guest    @relation("ToGuest", fields: [relatedId], references: [id], onDelete: Cascade)
  weddingId String
  wedding   Wedding  @relation(fields: [weddingId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([guestId, relatedId, type])
  @@index([weddingId])
  @@index([guestId])
}
