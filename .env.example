# ============================================================================
# .env.example — copie para .env e preencha. NUNCA commite o .env real.
# Em produção (Vercel) defina cada chave em Project Settings → Environment Variables.
# ============================================================================

# ─── Etapa 1: Banco (PostgreSQL) ───────────────────────────────
# Local (docker): docker run --name casamento-pg -e POSTGRES_PASSWORD=postgres -e POSTGRES_DB=casamento -p 5432:5432 -d postgres:16
# Prod: use uma URL gerenciada (Neon, Supabase, Vercel Postgres). Em serverless,
# prefira a connection string com pooling (PgBouncer / ?pgbouncer=true).
DATABASE_URL="postgresql://usuario:senha@localhost:5432/casamento?schema=public"

# Conexão DIRETA (sem pooling) do Neon — usada pelo Prisma como `directUrl`
# para migrations/introspection (PgBouncer não suporta esses comandos).
# No Neon é a connection string "unpooled"; defina-a também na Vercel.
# Em Postgres local sem pooler, pode repetir o valor de DATABASE_URL.
DATABASE_URL_UNPOOLED="postgresql://usuario:senha@localhost:5432/casamento?schema=public"

# ─── Auth (NextAuth v5) ────────────────────────────────────────
# Gere o segredo com: openssl rand -base64 32
AUTH_SECRET="gere-com-openssl-rand-base64-32"
# URL canônica do app. Usada por auth, e-mails e metadados de SEO (metadataBase).
# Em prod: https://seudominio.com  (sem barra no final)
NEXTAUTH_URL="http://localhost:3000"

# ─── Etapa 2: OAuth (Google) — ainda NÃO implementado ──────────
# GOOGLE_CLIENT_ID=""
# GOOGLE_CLIENT_SECRET=""

# ─── Seed: conta super-admin (prisma/seed.ts) ──────────────────
# Sem esses valores o seed pula a criação do admin e exibe aviso.
ADMIN_EMAIL="admin@seudominio.com"
ADMIN_PASSWORD="troque-por-senha-forte"

# ─── Etapa 3: Stripe ───────────────────────────────────────────
# Chaves em https://dashboard.stripe.com/apikeys
# Webhook local: stripe listen --forward-to localhost:3000/api/stripe/webhook
STRIPE_SECRET_KEY="sua_chave_secreta_stripe_aqui"
STRIPE_WEBHOOK_SECRET="seu_segredo_webhook_aqui"
# Price IDs por plano pago (Stripe → Products). Ver src/lib/plans.ts
STRIPE_PRICE_PRO="price_xxxxxxxxxxxxxxxxxxxxxxxx"
STRIPE_PRICE_GESTOR="price_xxxxxxxxxxxxxxxxxxxxxxxx"

# ─── Etapa 4: Rate Limiting (Upstash Redis) ────────────────────
# Crie um banco em https://console.upstash.com → REST API.
# Sem essas variáveis o rate limit vira no-op (libera tudo) — defina
# em produção para ativar a proteção. Ver src/lib/rate-limit.ts
UPSTASH_REDIS_REST_URL="https://seu-banco.upstash.io"
UPSTASH_REDIS_REST_TOKEN="seu-token-rest-do-upstash"

# ─── Etapa 4: E-mails transacionais (Resend) ───────────────────
# API key em https://resend.com/api-keys. Sem ela o envio vira no-op
# (loga e segue). EMAIL_FROM precisa de domínio verificado em prod;
# em teste use o remetente padrão. Ver src/lib/mail.ts
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxxxxxx"
EMAIL_FROM="Atelier do Sim <onboarding@resend.dev>"
