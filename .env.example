# ─── Etapa 1: Banco (PostgreSQL) ───────────────────────────────
# Local (docker): docker run --name casamento-pg -e POSTGRES_PASSWORD=postgres -e POSTGRES_DB=casamento -p 5432:5432 -d postgres:16
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/casamento?schema=public"

# ─── Auth (NextAuth v5) ────────────────────────────────────────
# Gere com: openssl rand -base64 32
AUTH_SECRET="change-me-in-prod-use-openssl-rand-base64-32"
NEXTAUTH_URL="http://localhost:3000"

